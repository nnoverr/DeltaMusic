{
    "version": 2,
    "buildCommand": null,
    "outputDirectory": ".",
    "framework": null,
    "rewrites": [
        {
            "source": "/api/proxy",
            "destination": "/api/proxy.js"
        }
    ],
    "headers": [
        {
            "source": "/(.*)",
            "headers": [
                {
                    "key": "Access-Control-Allow-Origin",
                    "value": "*"
                },
                {
                    "key": "Cache-Control",
                    "value": "no-store"
                }
            ]
        }
    ]
}